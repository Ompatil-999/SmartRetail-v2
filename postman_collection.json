{
  "info": {
    "name": "SmartRetail API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "SmartRetail SaaS API — Multi-Store Retail Management"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerName\": \"John Doe\",\n  \"email\": \"john@store.com\",\n  \"password\": \"password123\",\n  \"storeName\": \"John's Electronics\",\n  \"gstNumber\": \"29ABCDE1234F1Z5\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": ["var data = pm.response.json(); if(data.data && data.data.token){ pm.collectionVariables.set('token', data.data.token); }"] } }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@store.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [{ "listen": "test", "script": { "exec": ["var data = pm.response.json(); if(data.data && data.data.token){ pm.collectionVariables.set('token', data.data.token); }"] } }]
        }
      ]
    },
    {
      "name": "Store",
      "item": [
        {
          "name": "Get Store",
          "request": { "method": "GET", "url": "{{baseUrl}}/store" }
        },
        {
          "name": "Update Store",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/store",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeName\": \"John's Electronics Updated\",\n  \"gstNumber\": \"29ABCDE1234F1Z5\",\n  \"defaultTaxRate\": 18.00,\n  \"address\": \"123 Main St\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "Dashboard",
          "request": { "method": "GET", "url": "{{baseUrl}}/store/dashboard" }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics\",\n  \"description\": \"Electronic gadgets and devices\"\n}" }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/categories/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Electronics Updated\",\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Delete",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/categories/1" }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All",
          "request": { "method": "GET", "url": "{{baseUrl}}/products" }
        },
        {
          "name": "Search",
          "request": { "method": "GET", "url": "{{baseUrl}}/products?search=phone" }
        },
        {
          "name": "Low Stock",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/low-stock" }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Smartphone X\",\n  \"description\": \"Latest smartphone\",\n  \"price\": 29999.00,\n  \"barcode\": \"8901234567890\",\n  \"stockQty\": 50,\n  \"lowStockThreshold\": 10,\n  \"categoryId\": 1\n}" }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get All",
          "request": { "method": "GET", "url": "{{baseUrl}}/customers" }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/customers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"9876543210\"\n}" }
          }
        },
        {
          "name": "Purchase History",
          "request": { "method": "GET", "url": "{{baseUrl}}/customers/1/bills" }
        }
      ]
    },
    {
      "name": "Billing",
      "item": [
        {
          "name": "Get All Bills",
          "request": { "method": "GET", "url": "{{baseUrl}}/bills" }
        },
        {
          "name": "Create Bill",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bills",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"customerId\": 1,\n  \"billDiscount\": 50.00,\n  \"items\": [\n    {\n      \"productId\": 1,\n      \"quantity\": 2,\n      \"discount\": 100.00\n    }\n  ]\n}" }
          }
        }
      ]
    },
    {
      "name": "Offers",
      "item": [
        {
          "name": "Get All",
          "request": { "method": "GET", "url": "{{baseUrl}}/offers" }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/offers",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Summer Sale\",\n  \"description\": \"Get amazing discounts this summer!\",\n  \"discount\": 20.00,\n  \"validFrom\": \"2026-03-01\",\n  \"validTill\": \"2026-04-30\"\n}" }
          }
        }
      ]
    }
  ]
}
